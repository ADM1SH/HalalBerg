{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "cd backend && .venv/bin/python manage.py runserver 0.0.0.0:8001"],
      "port": 8001
    },
    {
      "name": "frontend",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "cd frontend && npm run dev"],
      "port": 3000
    }
  ]
}
