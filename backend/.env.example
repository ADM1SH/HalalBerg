# HalalBurg Terminal — Environment Variables
# Copy this to .env and fill in your API keys.
# The terminal will run without keys, but live data will be unavailable.

# Financial Modeling Prep (free tier)
# Get yours at: https://financialmodelingprep.com/developer/docs/
FMP_API_KEY=your_fmp_api_key_here

# NewsAPI (free tier, 100 requests/day)
# Get yours at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# GoldAPI.io (free tier)
# Get yours at: https://www.goldapi.io/
GOLD_API_KEY=your_goldapi_key_here

# LM Studio — local LLM (no key needed, just run LM Studio on this port)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=llama-3-8b-instruct

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-in-production
DJANGO_DEBUG=True

# Currency settings
DEFAULT_CURRENCY=MYR
# USD/MYR exchange rate fallback (used if no live rate available)
FALLBACK_USD_MYR=4.70
